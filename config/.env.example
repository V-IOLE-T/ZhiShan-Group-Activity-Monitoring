# ========== 必需配置 ==========
APP_ID=cli_xxxxx
APP_SECRET=xxxxx
CHAT_ID=oc_xxxxx
BITABLE_APP_TOKEN=xxxxx
BITABLE_TABLE_ID=xxxxx

# ========== 可选配置 ==========
# 公告专表（可选）
ARCHIVE_TABLE_ID=xxxxx
# 不填则默认识别 公告,通知；需要扩展时再配置，例如 公告,通知,系统播报
# ANNOUNCEMENT_TAGS=公告,通知,系统播报

# Pin功能配置
PIN_TABLE_ID=xxxxx
# 每周Pin审计: 每周一 9:00 自动执行（汇总上周新增 Pin）

# 月度归档功能
ARCHIVE_STATS_TABLE_ID=xxxxx

# ========== 高级配置(可选) ==========
# 健康检查HTTP端口
HEALTH_CHECK_PORT=8080

# 自动重连配置
MAX_RETRIES=10
RETRY_DELAY=30

# 活跃度批量写入兜底刷新间隔（秒）
BATCH_FLUSH_INTERVAL_SECONDS=30
