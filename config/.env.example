# ========== 必需配置 ==========
APP_ID=cli_xxxxx
APP_SECRET=xxxxx
CHAT_ID=oc_xxxxx
BITABLE_APP_TOKEN=xxxxx
BITABLE_TABLE_ID=xxxxx

# ========== 可选配置 ==========
# 消息归档功能
ARCHIVE_TABLE_ID=xxxxx
SUMMARY_TABLE_ID=xxxxx
ANNOUNCEMENT_TAGS=公告,通知

# Pin功能配置
PIN_TABLE_ID=xxxxx
# 每日Pin审计: 每天 9:00 自动执行
# 无需配置间隔时间

# ========== 高级配置(可选) ==========
# 健康检查HTTP端口
HEALTH_CHECK_PORT=8080

# 自动重连配置
MAX_RETRIES=10
RETRY_DELAY=30
